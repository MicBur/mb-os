#!/bin/sh

# Ensure XDG_RUNTIME_DIR exists and has correct permissions for mbuser
export XDG_RUNTIME_DIR=/tmp/runtime-mbuser
export HOME=/home/mbuser
mkdir -p $XDG_RUNTIME_DIR
chown mbuser:mbuser $XDG_RUNTIME_DIR
chmod 700 $XDG_RUNTIME_DIR

# Allow local connections to X server from mbuser
xhost +local:mbuser || xhost +local: || true

# Set German keyboard layout
setxkbmap de || true

# Set mouse cursor theme (WICHTIG!)
export XCURSOR_THEME=DMZ-White
export XCURSOR_SIZE=24
xsetroot -cursor_name left_ptr 2>/dev/null || true

# Force software cursor for Intel/Celeron (hardware cursor invisible on some chips)
mkdir -p /etc/X11/xorg.conf.d
cat > /etc/X11/xorg.conf.d/20-cursor.conf << 'XCURSOR'
Section "Device"
    Identifier "Default"
    Option "SWCursor" "true"
EndSection
XCURSOR

# Write cursor config for mbuser
mkdir -p /home/mbuser
echo 'Xcursor.theme: DMZ-White' > /home/mbuser/.Xresources
echo 'Xcursor.size: 24' >> /home/mbuser/.Xresources
chown mbuser:mbuser /home/mbuser/.Xresources 2>/dev/null || true

# DHCP fallback (in case systemd-networkd didn't match the interface)
dhclient -nw 2>/dev/null || true

# Set best available resolution
xrandr --output default --mode 1280x1024 2>/dev/null || \
xrandr --output Virtual1 --mode 1280x1024 2>/dev/null || \
xrandr --output screen --mode 1280x1024 2>/dev/null || \
xrandr -s 1280x1024 2>/dev/null || \
xrandr -s 1024x768 2>/dev/null || true

# Disable screen saver and power management
xset -dpms || true
xset s off || true
xsetroot -solid "#0a0c16" || true

# Load custom Xresources (xterm colors, fonts)
if [ -f /home/mbuser/.Xresources ]; then
    xrdb -merge /home/mbuser/.Xresources || true
fi

# Start dunst notification daemon (dark theme matching MB-OS)
mkdir -p /home/mbuser/.config/dunst
cat > /home/mbuser/.config/dunst/dunstrc << 'DUNSTCONF'
[global]
    monitor = 0
    follow = mouse
    width = 350
    height = 100
    offset = 20x40
    origin = top-right
    transparency = 15
    frame_color = "#20c2f8"
    frame_width = 2
    corner_radius = 12
    font = Inter 11
    markup = full
    format = "<b>%a</b>\n%s\n%b"
    show_age_threshold = 30
    idle_threshold = 120
    icon_position = left
    max_icon_size = 48

[urgency_low]
    background = "#0f1118"
    foreground = "#a0a5c0"
    timeout = 5

[urgency_normal]
    background = "#0f1118"
    foreground = "#e2e8f0"
    timeout = 8

[urgency_critical]
    background = "#1a0510"
    foreground = "#ff4060"
    frame_color = "#ff4060"
    timeout = 0
DUNSTCONF
chown -R mbuser:mbuser /home/mbuser/.config/dunst
runuser -u mbuser -- env HOME="/home/mbuser" DISPLAY="$DISPLAY" dunst &

# Start the Openbox window manager in the background as mbuser
runuser -u mbuser -- env HOME="/home/mbuser" PATH="/usr/local/bin:/usr/bin:/bin" DISPLAY="$DISPLAY" XDG_RUNTIME_DIR="$XDG_RUNTIME_DIR" XCURSOR_THEME=DMZ-White XCURSOR_SIZE=24 QML2_IMPORT_PATH="/usr/lib/x86_64-linux-gnu/qt6/qml" QT_PLUGIN_PATH="/usr/lib/x86_64-linux-gnu/qt6/plugins" openbox &
OPENBOX_PID=$!

# Start Memory Daemon (FastAPI on port 8000)
runuser -u mbuser -- env HOME="/home/mbuser" MEMORY_DIR="/home/mbuser/.mb-os/memory" python3 /usr/local/share/mb-os/memory_daemon.py > /tmp/memory-daemon.log 2>&1 &

# Start our custom Qt 6 Desktop Shell as mbuser
runuser -u mbuser -- env HOME="/home/mbuser" PATH="/usr/local/bin:/usr/bin:/bin" DISPLAY="$DISPLAY" XDG_RUNTIME_DIR="$XDG_RUNTIME_DIR" XCURSOR_THEME=DMZ-White XCURSOR_SIZE=24 QML2_IMPORT_PATH="/usr/lib/x86_64-linux-gnu/qt6/qml" QT_PLUGIN_PATH="/usr/lib/x86_64-linux-gnu/qt6/plugins" /usr/local/bin/mb-os-shell 2>/tmp/mb-shell-error.log &
SHELL_PID=$!

# Wait for shell to start, then launch WhatsApp desktop app minimized
(sleep 8; runuser -u mbuser -- env HOME="/home/mbuser" DISPLAY="$DISPLAY" /snap/bin/whatsapp-linux-desktop --no-sandbox &
sleep 5; DISPLAY="$DISPLAY" xdotool search --name "WhatsApp" windowminimize 2>/dev/null) &

# Wait for the shell to exit
wait $SHELL_PID

# FALLBACK: Wenn mb-os-shell crasht, Desktop trotzdem nutzbar halten
echo ">>> mb-os-shell beendet (Code: $?), starte Fallback-Desktop..." >> /tmp/mb-gui.log
cat /tmp/mb-shell-error.log >> /tmp/mb-gui.log 2>/dev/null

# PCManFM als Desktop + xterm als Terminal
runuser -u mbuser -- env DISPLAY="$DISPLAY" HOME="/home/mbuser" pcmanfm --desktop &
runuser -u mbuser -- env DISPLAY="$DISPLAY" HOME="/home/mbuser" xterm -fa "Monospace" -fs 14 -bg "#0a0c16" -fg "#00ffcc" -T "MB-OS Terminal" -e bash -c "echo '=== MB-OS Fallback Desktop ==='; echo 'mb-os-shell konnte nicht starten (Qt Version?).'; echo 'Log: cat /tmp/mb-shell-error.log'; echo ''; exec bash" &

# Warte auf Openbox (hält den Desktop am Leben)
wait $OPENBOX_PID

